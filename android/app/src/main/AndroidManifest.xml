<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.rexglue.renut">

    <!-- Vulkan requires OpenGL ES 3.1+ hardware -->
    <uses-feature android:glEsVersion="0x00030001" android:required="true" />

    <!-- Storage access for reading game library from user-selected folder -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Full file access (API 30+) so native fopen() can read game files
         from any user-selected path under /storage/emulated/0/ -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <application
        android:label="reNut"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:hasCode="true"
        android:allowBackup="false"
        android:supportsRtl="true">

        <activity
            android:name=".RenutActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:screenOrientation="sensorLandscape"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
